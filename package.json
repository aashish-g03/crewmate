{
  "name": "crewmate",
  "version": "0.2.0",
  "description": "Localhost agent-mesh CLI — delegate work from one CLI agent (Claude Code) to others (Gemini, Kimi, Codex) via a filesystem mailbox. Inspired by Claude Code's internal cross-process teammate pattern.",
  "keywords": [
    "agent",
    "agent-mesh",
    "claude-code",
    "gemini-cli",
    "kimi",
    "codex",
    "mailbox",
    "orchestration",
    "multi-agent"
  ],
  "author": "Aashish Gupta <aashishg2003@gmail.com>",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aashish-g03/crewmate.git"
  },
  "bugs": {
    "url": "https://github.com/aashish-g03/crewmate/issues"
  },
  "homepage": "https://github.com/aashish-g03/crewmate#readme",
  "bin": {
    "crewmate": "./bin/crewmate"
  },
  "files": [
    "bin/",
    "src/",
    "templates/",
    "README.md",
    "AGENTS.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.3.13"
  },
  "scripts": {
    "start": "bun src/cli.ts",
    "dev": "bun --watch src/cli.ts",
    "validate": "bash scripts/validate.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "chokidar": "^4.0.0",
    "uuid": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.6.0"
  }
}
